# Server
NODE_ENV=development
PORT=3000

# CORS — frontend dev server URL
FRONTEND_URL=http://localhost:5173

# ── Phase 02 will add ──────────────────────────
DATABASE_URL=

# ── Phase 05 ──────────────────────────────────────────────────────────────────
SESSION_SECRET=<generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))">
SESSION_DAYS=7

# ── Phase 06 ──────────────────────────────────────────────────────────────────
# Leave SMTP_HOST blank in development — emails are printed to the console instead
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Vernal <noreply@vernal.garden>
APP_URL=http://localhost:3000
BCRYPT_ROUNDS=12

# ── Phase 07 ──────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ENCRYPTION_KEY=       # 32 bytes as 64 hex chars — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

GUEST_SESSION_DAYS=30

